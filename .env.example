# AI-Companion Environment Configuration

# Remote LLM Endpoint (e.g., Google Colab Bridge or local tunnel)
# REMOTE_LLM_URL=https://your-colab-url.ngrok.io

# Remote TTS Endpoint (if using remote XTTS bridge)
# REMOTE_TTS_URL=https://your-tts-url.ngrok.io

# Default LLM Model Name (Ollama or Remote)
DEFAULT_LLM_MODEL=fluffy/l3-8b-stheno-v3.2

# Debug Mode
DEBUG_MODE=false
